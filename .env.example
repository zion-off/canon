# Canon — enviroment variables for docker compose
# Copy to .env and fill in values before running docker compose up

# MongoDB connection string (required)
MONGODB_URI=mongodb://mongo:27017/canon

# JWT signing secret (required — generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Model configuration (optional — defaults shown)
# CANON_REASONING_MODEL=gemini-3.1-pro
# CANON_FAST_MODEL=gemini-3.1-flash
# CANON_EMBEDDING_MODEL=text-embedding-004

# Backend URL for the frontend to call
API_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000