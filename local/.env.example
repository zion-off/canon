# Canon — enviroment variables for docker compose
# Copy to .env and fill in values before running docker compose up

# MongoDB connection string (required)
MONGODB_URI=mongodb://mongo:27017/canon

# JWT signing secret (required — generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Google Cloud project (required for Vertex AI with ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Model configuration (optional)
CANON_REASONING_MODEL=gemini-3.1-pro
CANON_FAST_MODEL=gemini-3.1-flash
CANON_EMBEDDING_MODEL=text-embedding-004

# Backend URL for the frontend to call (Docker internal DNS)
API_URL=http://backend:8000
# Public-facing API URL (browser-side, uses host port)
NEXT_PUBLIC_API_URL=http://localhost:8400

# Signup email allowlist (comma or space separated; empty = open signups)
SIGNUP_ALLOWLIST=